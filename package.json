{
  "name": "poc_bbc",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dbtest": "npx playwright test --project=db",
    "uitest": "npx bddgen && npx playwright test --project=uitest --headed",
    "report": "npx playwright show-report",
    "schdtest": "npx bddgen && npx playwright test --project=uitest --grep @schdTeamUI --headed",
    "facilitytest": "npx bddgen && npx playwright test --project=uitest --grep @facility --headed",
    "all:report": "npx bddgen && npx playwright test && npm run report",
    "facilitytest:dev": "cross-env ENVIRONMENT=dev npm run facilitytest",
    "facilitytest:systest": "cross-env ENVIRONMENT=systest npm run facilitytest",
    "schdtest:dev": "cross-env ENVIRONMENT=dev npm run schdtest",
    "schdtest:systest": "cross-env ENVIRONMENT=systest npm run schdtest",
    "uitest:dev": "cross-env ENVIRONMENT=dev npm run uitest",
    "uitest:systest": "cross-env ENVIRONMENT=systest npm run uitest",
    "facilitytest:ci": "npx bddgen && ENVIRONMENT=$ENVIRONMENT npx playwright test --project=uitest --grep @facility",
    "schdtest:ci": "npx bddgen && ENVIRONMENT=$ENVIRONMENT npx playwright test --project=uitest --grep @schdTeamUI",
    "uitest:ci": "npx bddgen && ENVIRONMENT=$ENVIRONMENT npx playwright test --project=uitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/mssql": "^9.1.9",
    "@types/node": "^25.2.3",
    "cross-env": "^10.1.0",
    "http-server": "^14.1.1",
    "playwright-bdd": "^8.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "mssql": "^12.2.0"
  }
}
