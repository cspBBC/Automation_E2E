# Environment Configuration Template
# Copy this file to .env.{environment} and fill in your credentials
# Replace {environment} with: dev, systest, staging, prod, etc.

# Database Configuration
DB_AUTH_TYPE=sql
DB_HOST=your-db-host.national.core.bbc.co.uk
DB_NAME=BBCSchedules_WP
DB_USER=your-database-user
DB_PASSWORD=your-database-password

# API Configuration
API_BASE_URL=https://allocate-systest-dbr.national.core.bbc.co.uk

# UI Configuration
UI_BASE_URL=https://allocate-systest-wp.national.core.bbc.co.uk

# Authentication Credentials
SYS_ADMIN_PASSWORD=your-system-admin-password
AREA_ADMIN_PASSWORD=your-area-admin-password
AREA_ADMIN_1_PASSWORD=your-area-admin-1-password
REGULAR_USER_PASSWORD=your-regular-user-password

# Environment Identifier
ENVIRONMENT=dev
